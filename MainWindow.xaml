<Window x:Class="CrustUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrustGame - Gaming Performance Optimizer"
        Width="600" Height="500"
        Background="#1e1e1e"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="icon.png"
        Closing="Window_Closing">
    
    <Grid Background="#1e1e1e">
        <StackPanel Margin="20">
            <TextBlock Text="CrustGame" FontSize="28" FontWeight="Bold" Foreground="#00ff00" Margin="0,0,0,10"/>
            <TextBlock Text="Extreme Gaming Performance Optimizer" FontSize="12" Foreground="#888888" Margin="0,0,0,20"/>
            <Button x:Name="GamingModeButton" Content="Gaming Mode: OFF" Width="200" Height="50" FontSize="16" FontWeight="Bold" Background="#333333" Foreground="White" Click="GamingModeButton_Click" Margin="0,0,0,20"/>
            <GroupBox Header="System Metrics" Foreground="White" Background="#252525" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock x:Name="CPUUsageText" Text="CPU Usage: 0.0%" Margin="0,5"/>
                    <TextBlock x:Name="RAMUsageText" Text="RAM Usage: 0.0%" Margin="0,5"/>
                    <TextBlock x:Name="GPUUsageText" Text="GPU Usage: 0.0%" Margin="0,5"/>
                    <TextBlock x:Name="DPCLatencyText" Text="DPC Latency: 0.00ms" Margin="0,5"/>
                    <TextBlock x:Name="HealthText" Text="System Health: Stable" Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            <StackPanel Orientation="Horizontal">
                <Button Content="Settings" Width="100" Height="35" Background="#333333" Foreground="White" Margin="0,0,10,0"/>
                <Button x:Name="ResetButton" Content="Reset Defaults" Width="100" Height="35" Background="#333333" Foreground="White" Click="ResetButton_Click"/>
            </StackPanel>
            <TextBlock Text="Ready" FontSize="10" Foreground="#666666" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>
